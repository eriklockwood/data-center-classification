# Data — keep dirs but ignore contents
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Local env files
.env
.env.local

# Claude Code per-user settings (shared settings.json may be committed)
.claude/settings.local.json
